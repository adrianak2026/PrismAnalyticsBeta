{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "src/app", "src/db"]
}
